# Next.js Frontend Environment Variables

# Database
DATABASE_URL=postgresql://user:password@host:port/vistabite

# Groq API for AI Features
GROQ_API_KEY=your_groq_api_key_here

# RapidAPI for Instagram Reels Search
RAPIDAPI_KEY=your_rapidapi_key_here

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=your_admin_email@example.com

# Python Microservices (Local Development)
NEXT_PUBLIC_CONTENT_ANALYZER_URL=http://localhost:8001
NEXT_PUBLIC_ANALYTICS_URL=http://localhost:8002

# Frontend URL
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
